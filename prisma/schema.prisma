datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  role          String          @default("user") // "user" or "admin"
  accounts      Account[]
  sessions      Session[]
  // WebAuthn support
  Authenticator Authenticator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt DateTime?

  // Personal data
  examProgress   ExamProgress[]
  calendarEvents CalendarEvent[]
  comments       Comment[]
  links          Link[]
  auditLogs      AuditLog[]
  podcastVotes   PodcastVote[]
  postVotes      PostVote[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String  @id @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("authenticators")
}

// Student progress tracking
model ExamProgress {
  id          String   @id @default(cuid())
  userId      String
  examTitle   String   // e.g., "Aprobar IVU", "Parcial 1"
  type        String   // "autoevaluacion" or "parcial"
  subject     String?
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("exam_progresses")
}

// Admin managed content
model Link {
  id          String   @id @default(cuid())
  name        Json     // { "es": "...", "en": "...", "pt": "..." }
  url         String
  description Json?    // { "es": "...", "en": "...", "pt": "..." }
  iconType    String?  // wsp, discord, drive, moodle, siu, youtube, external
  order       Int      @default(0)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("links")
}

model Post {
  id              String      @id @default(cuid())
  title           Json        // { "es": "...", "en": "...", "pt": "..." }
  content         Json        // { "es": "...", "en": "...", "pt": "..." }
  slug            String      @unique
  alternativeSlug  String?     @unique
  alternativeSlug2 String?     @unique
  description     Json?       // { "es": "...", "en": "...", "pt": "..." }
  published       Boolean     @default(false)
  date            DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  comments        Comment[]
  countdowns      Countdown[]
  votes           PostVote[]

  @@map("posts")
}

model Podcast {
  id          String   @id @default(cuid())
  title       Json     // { "es": "...", "en": "...", "pt": "..." }
  description Json?    // { "es": "...", "en": "...", "pt": "..." }
  slug        String   @unique
  audioUrl    String
  subjectId   String?  // ID related to subjectNames in translations
  links       Json?    // Array of { title, url }
  published   Boolean  @default(false)
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  comments    Comment[]
  votes       PodcastVote[]

  @@map("podcasts")
}

model PodcastVote {
  id        String   @id @default(cuid())
  userId    String
  podcastId String
  type      String   // "LIKE" or "DISLIKE"
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  podcast   Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([userId, podcastId])
  @@map("podcast_votes")
}

model PostVote {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  type      String   // "LIKE" or "DISLIKE"
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@map("post_votes")
}

model Image {
  id        String   @id @default(cuid())
  slug      String   @unique
  url       String   // Supabase Storage URL
  filename  String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("images")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  postId    String?
  podcastId String?
  userId    String
  parentId  String?
  images    Json?    @default("[]")
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  podcast Podcast? @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       Json     // { "es": "...", "en": "...", "pt": "..." }
  description Json?
  startDate   DateTime
  endDate     DateTime?
  period      String?  // e.g., "1st Semester", "Full Year"
  type        String   @default("event") // "exam", "class", "admin", "event"
  subjectId   String?  // ID related to subjectNames in translations
  url         String?
  userId      String?  // Personal event for a user
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("calendar_events")
}

model Notification {
  id          String   @id @default(cuid())
  message     Json     // { "es": "...", "en": "...", "pt": "..." }
  description Json?    // { "es": "...", "en": "...", "pt": "..." }
  type        String   @default("info") // info, warning, danger, success
  active      Boolean  @default(true)
  url         String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notifications")
}

model Countdown {
  id          String   @id @default(cuid())
  slot        String?  // "left" or "right"
  postId      String?
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  title       Json     // { "es": "...", "en": "...", "pt": "..." }
  targetDate  DateTime
  description Json?    // { "es": "...", "en": "...", "pt": "..." }
  expiredMessage Json?    // { "es": "...", "en": "...", "pt": "..." }
  url         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([postId, slot])
  @@map("countdowns")
}
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // "CREATE", "UPDATE", "DELETE", "TOGGLE"
  target    String   // "link", "notification", "post", "event"
  details   String?  // e.g., "Updated link Google Drive"
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model AdminNote {
  id        String   @id @default(cuid())
  section   String   @unique // 'notifications', 'posts', 'calendar', 'countdowns'
  content   String   @default("") @db.Text
  updatedAt DateTime @updatedAt

  @@map("admin_notes")
}
